#include <stdio.h>

int main() {
    int frames, pages, i, j, k, pageFaults = 0;

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    printf("Enter number of pages: ");
    scanf("%d", &pages);

    int page[pages], frame[frames];

    printf("Enter page reference string:\n");
    for (i = 0; i < pages; i++)
        scanf("%d", &page[i]);

    // Initialize frames as empty
    for (i = 0; i < frames; i++)
        frame[i] = -1;

    int front = 0;

    printf("\nPage\tFrames\n");

    for (i = 0; i < pages; i++) {
        int found = 0;

        // Check if page is already in frame
        for (j = 0; j < frames; j++) {
            if (frame[j] == page[i]) {
                found = 1;
                break;
            }
        }

        // Page fault
        if (!found) {
            frame[front] = page[i];
            front = (front + 1) % frames;
            pageFaults++;
        }

        printf("%d\t", page[i]);
        for (k = 0; k < frames; k++) {
            if (frame[k] == -1)
                printf("- ");
            else
                printf("%d ", frame[k]);
        }
        printf("\n");
    }

    printf("\nTotal Page Faults = %d\n", pageFaults);

    return 0;
}
