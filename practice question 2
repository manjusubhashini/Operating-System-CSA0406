#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>
#include <sys/wait.h>

int main() {
    pid_t pid1, pid2;

 
    pid1 = fork();

    if (pid1 == 0) {
        printf("First Child Process\n");
        printf("PID: %d, Parent PID: %d\n", getpid(), getppid());
        return 0;
    }
    pid2 = fork();

    if (pid2 == 0) {
        printf("Second Child Process\n");
        printf("PID: %d, Parent PID: %d\n", getpid(), getppid());
        return 0;
    }

    printf("Parent Process\n");
    printf("PID: %d\n", getpid());
    wait(NULL);
    wait(NULL);

    return 0;
}
