exit (to terminate the program properly)
b)
read(int fd, void *buf, size_t count): This system call copies a specified number of bytes from an open file associated
write(int fd, const void *buf, size_t count): This system call takes a specified number of bytes from a memory buffer and writes them into the file associated.
c)
#include <fcntl.h>
#include <unistd.h>
int main() {
int src = open("source.txt", O_RDONLY);
int dest = open("dest.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);
char buf[1024];
int n;
while ((n = read(src, buf, sizeof(buf))) > 0)
write(dest, buf, n);
close(src);
close(dest);
return 0;
}

