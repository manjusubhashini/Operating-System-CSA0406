#include <stdio.h>
int main() {
    int n, pid[10], i;
printf("Enter the number of processes: ");
scanf("%d", &n);
    for (i = 0; i < n; i++) {
        printf("Enter Process ID %d: ", i + 1);
        scanf("%d", &pid[i]);
    }
printf("\n--- Process Execution Order ---\n");
    for (i = 0; i < n; i++) {
        printf("Executing Process P%d\n", pid[i]);
    }

    printf("\nAll processes executed successfully.\n");

    return 0;
}
